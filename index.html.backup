    <!-- FAQ Section -->
    <section class="faq">
        <div class="faq-container">
            <h2>Frequently Asked Questions</h2>
            
            <div class="faq-item">
                <div class="faq-question">What's included in The DTV Guide?</div>
                <div class="faq-answer">The guide is a comprehensive PDF covering every step of the DTV application: eligibility requirements, document preparation, embassy-specific nuances, common rejection reasons, and my AI-assisted formatting system. You also get templates, checklists, and 12 months of updates.</div>
            </div>
            
            <div class="faq-item">
                <div class="faq-question">How is this different from free info online?</div>
                <div class="faq-answer">Free info is often outdated, generic, or wrong. Embassy requirements change. The DTV Guide is kept current, includes embassy-specific details, and gives you the exact document formatting system I built — which isn't documented anywhere else. Plus, the £300 government fee is non-refundable. Getting it wrong is expensive.</div>
            </div>
            
            <div class="faq-item">
                <div class="faq-question">Can I apply from inside Thailand?</div>
                <div class="faq-answer">In most cases, no. The DTV is designed to be applied for from your home country or a country where you have residency. If you're already in Thailand on a tourist visa, you'll typically need to leave to apply. The guide covers the best strategies for your situation.</div>
            </div>
            
            <div class="faq-item">
                <div class="faq-question">What if I don't have £11,500 saved yet?</div>
                <div class="faq-answer">The 500,000 THB requirement is strict — you need to show it in your account. If you don't have it yet, the consultation call can help you plan your timeline. I won't sell you the guide if you're not ready.</div>
            </div>
            
            <div class="faq-item">
                <div class="faq-question">Is this guaranteed to get me approved?</div>
                <div class="faq-answer">No — embassies make the final decision. What I guarantee is that you'll submit the strongest possible application with correctly formatted documents. I've used this exact system myself and helped others get approved. I also guarantee you'll save 10+ hours of research.</div>
            </div>
            
            <div class="faq-item">
                <div class="faq-question">How long does the DTV last?</div>
                <div class="faq-answer">The DTV is a 5-year multiple entry visa. Each stay can be up to 180 days. You can extend once per entry for another 180 days (for a fee), meaning you could potentially stay continuously for up to 1 year before needing a border run.</div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <h2>Ready to make Thailand your base?</h2>
        <p>The 60-day rule is ending. The DTV is your path to long-term, legal stays. Start with the free quiz — it takes 2 minutes.</p>
        <a href="#quiz" class="btn btn-primary">Check My Eligibility</a>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 The DTV Guide. Built by a UK entrepreneur who actually did this.</p>
        <p style="margin-top: 0.5rem;">Not legal advice. Always verify current requirements with the Thai embassy.</p>
    </footer>

    <script>
        // Quiz Logic
        const questions = document.querySelectorAll('.quiz-question');
        const progressBars = document.querySelectorAll('.quiz-progress-bar');
        const resultLikely = document.getElementById('result-likely');
        const resultChallenges = document.getElementById('result-challenges');
        const resultNoRemote = document.getElementById('result-no-remote');
        const resultNeedPermission = document.getElementById('result-need-permission');
        const resultLowIncome = document.getElementById('result-low-income');
        
        let currentQuestion = 0;
        const answers = {};
        let questionPath = []; // Track which questions were shown

        // Handle option clicks
        document.querySelectorAll('.quiz-option').forEach(option => {
            option.addEventListener('click', function() {
                const questionEl = this.closest('.quiz-question');
                const questionId = questionEl.dataset.question;
                
                // Store answer
                answers[questionId] = this.dataset.value;
                questionPath.push(questionId);
                
                // Visual selection
                questionEl.querySelectorAll('.quiz-option').forEach(opt => opt.classList.remove('selected'));
                this.classList.add('selected');
                
                // Handle routing based on answers
                setTimeout(() => {
                    routeQuiz(questionId, this.dataset.value);
                }, 300);
            });
        });

        function routeQuiz(currentQId, answer) {
            // Hide current
            questions.forEach(q => q.classList.remove('active'));
            
            // Update progress bar based on how far we've gone
            const progressIndex = questionPath.length;
            progressBars.forEach((bar, index) => {
                bar.classList.toggle('active', index < progressIndex);
            });
            
            switch(currentQId) {
                case '1': // Remote income?
                    if (answer === 'no') {
                        showResult('no-remote');
                    } else {
                        showQuestion('2a');
                    }
                    break;
                    
                case '2a': // PAYE or self-employed?
                    if (answer === 'paye') {
                        showQuestion('2b');
                    } else {
                        showQuestion('2d'); // Self-employed path
                    }
                    break;
                    
                case '2b': // Workplace policy?
                    if (answer === 'yes') {
                        showQuestion('4'); // Skip to bank balance
                    } else {
                        showQuestion('2c'); // Ask if they've asked permission
                    }
                    break;
                    
                case '2c': // Asked permission?
                    if (answer === 'yes' || answer === 'asked-waiting') {
                        showQuestion('4'); // Continue
                    } else {
                        showResult('need-permission');
                    }
                    break;
                    
                case '2d': // Self-employed duration
                    showQuestion('2e');
                    break;
                    
                case '2e': // Tax return filed?
                    showQuestion('3');
                    break;
                    
                case '3': // Monthly income
                    if (answer === 'under-1k') {
                        showResult('low-income');
                    } else {
                        showQuestion('4');
                    }
                    break;
                    
                case '4': // Bank balance
                    showQuestion('5');
                    break;
                    
                case '5': // Employment proof
                    calculateFinalResult();
                    break;
            }
        }

        function showQuestion(questionId) {
            const nextQuestion = document.querySelector(`.quiz-question[data-question="${questionId}"]`);
            if (nextQuestion) {
                nextQuestion.classList.add('active');
            }
        }

        function showResult(resultId) {
            // Hide all questions
            questions.forEach(q => q.classList.remove('active'));
            document.querySelector('.quiz-progress').style.display = 'none';
            
            // Show appropriate result
            document.getElementById(`result-${resultId}`).classList.add('show');
        }

        function calculateFinalResult() {
            // Hide all questions
            questions.forEach(q => q.classList.remove('active'));
            document.querySelector('.quiz-progress').style.display = 'none';
            
            // Calculate qualification score
            let score = 0;
            let issues = [];
            
            // Q1: Must have remote income (already filtered)
            if (answers['1'] && answers['1'] !== 'no') score += 1;
            
            // Q4: Bank balance
            if (['yes-have', 'yes-savings'].includes(answers['4'])) {
                score += 2;
            } else if (answers['4'] === 'soon') {
                score += 1;
                issues.push('funds-soon');
            } else {
                issues.push('funds-no');
            }
            
            // Q5: Employment proof
            if (answers['5']) {
                score += 2;
            }
            
            // Self-employed specific checks
            if (answers['2a'] === 'self-employed') {
                if (answers['2e'] === 'yes-filed') score += 1;
                else if (answers['2e'] === 'overdue') issues.push('tax-overdue');
            }
            
            // Show result
            if (score >= 4 && issues.length === 0) {
                resultLikely.classList.add('show');
            } else {
                resultChallenges.classList.add('show');
            }
        }

        // FAQ Accordion
        document.querySelectorAll('.faq-question').forEach(question => {
            question.addEventListener('click', () => {
                const item = question.parentElement;
                const isOpen = item.classList.contains('open');
                
                // Close all
                document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
                
                // Open clicked if it was closed
                if (!isOpen) {
                    item.classList.add('open');
                }
            });
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
</body>
</html>